<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Platform theme used only until Compose takes over rendering. Compose owns the real
      Material 3 theming, so this stays minimal and dependency-free (no AppCompat/Material XML).
    -->
    <style name="Theme.ComposeReels" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
