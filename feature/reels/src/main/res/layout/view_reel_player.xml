<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView is inflated from XML so we can request a TextureView surface. A TextureView
  composites inside the normal view hierarchy, so the video draws above the thumbnail and below
  the Compose overlay. (A SurfaceView, the PlayerView default, renders behind the window and would
  be hidden by the opaque Compose content.) The transparent shutter lets the thumbnail show
  through while the first frame is still buffering.
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="zoom"
    app:shutter_background_color="@android:color/transparent" />
